generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ─────────────────────────────────────

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String?       @unique
  emailVerified    DateTime?
  image            String?
  plan             String        @default("FREE")
  paddleCustomerId String?  @unique
  currentOrgId     String?
  deletedAt        DateTime?
  onboardingCompleted Boolean       @default(false)
  notificationPrefs    String?       // JSON: { email: boolean, inApp: boolean, digest: "instant"|"daily"|"off" }
  emailUnsubscribeToken String?     @unique
  accounts         Account[]
  sessions         Session[]
  projects         ProjectMember[]
  orgMemberships   OrgMember[]
  activities       Activity[]
  assignedStories  Story[]        @relation("AssignedStories")
  comments         Comment[]
  notifications    Notification[]
  passwordHash        String?
  passwordResetToken  String?       @unique
  passwordResetExpiry DateTime?
  isAdmin             Boolean       @default(false)
  totpSecret          String?
  totpEnabled         Boolean       @default(false)
  totpBackupCodes     String?
  auditLogs        AuditLog[]     @relation("AuditLogs")
  subscription     Subscription?
  savedFilters     SavedFilter[]
  requestedApprovals  Approval[]        @relation("ApprovalRequester")
  decidedApprovals    Approval[]        @relation("ApprovalDecider")
  approvalComments    ApprovalComment[]
  readStates       ReadState[]
  currentOrg       Organization? @relation("UserCurrentOrg", fields: [currentOrgId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([currentOrgId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                     String        @id @default(cuid())
  userId                 String?       @unique
  orgId                  String?       @unique
  externalSubscriptionId String        @unique
  productId              String
  currentPeriodEnd       DateTime
  status                 String
  user                   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization           Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

// ─── Organization Models ────────────────────────────────

model Organization {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  plan             String        @default("FREE")
  paddleCustomerId String?  @unique
  isPersonal       Boolean       @default(false)
  issuePrefix      String?
  issueCounter     Int           @default(0)
  members          OrgMember[]
  projects         Project[]
  invites          OrgInvite[]
  auditLogs        AuditLog[]
  agents           Agent[]
  requireApprovalForAgents Boolean        @default(false)
  launchDate       DateTime?
  subscription     Subscription?
  usersWithCurrent User[]        @relation("UserCurrentOrg")
  budgetPolicies   BudgetPolicy[]
  approvals        Approval[]
  executionWorkspaces ExecutionWorkspace[]
  goals            Goal[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model OrgMember {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      String       @default("MEMBER")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
}

// ─── Application Models ──────────────────────────────────

model Project {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  techStack     String?
  githubRepo    String?
  githubInstallationId String?     // GitHub App installation id for per-tenant git auth
  orgId            String?
  webhookSecret    String?
  apiKey           String?         @unique
  apiKeyHash       String?
  apiKeyPrefix     String?
  apiKeyLastRotated DateTime?
  isPublic         Boolean         @default(false)
  agentAutoAssign  Boolean         @default(false)
  agentMinPriority String          @default("HIGH")
  agentWorkingDir  String?
  aiProvider       String          @default("ollama")
  aiApiKey         String?
  maxConcurrentAgents Int          @default(1)
  wipLimits        Json?           // { "TODO": 5, "IN_PROGRESS": 3, "REVIEW": 2 }
  deployProvider   String?
  deployToken      String?
  deployProjectId  String?
  org              Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members          ProjectMember[]
  stories       Story[]
  workspaces    ExecutionWorkspace[]
  sprints       Sprint[]
  labels        Label[]
  activities    Activity[]
  webhooks      Webhook[]
  recurringStories RecurringStory[]
  savedFilters  SavedFilter[]
  costEvents    CostEvent[]
  routines      Routine[]
  goals         Goal[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orgId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      String      @default("OWNER")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model Story {
  id                 String               @id @default(cuid())
  shortId            String               @unique
  title              String
  description        String?
  rawInput           String?
  userStory          String?
  status             String               @default("BACKLOG")
  priority           String               @default("MEDIUM")
  type               String               @default("feature")
  storyPoints        Int?
  position           Int                  @default(0)
  projectId          String
  sprintId           String?
  assigneeId         String?
  parentId           String?
  agentId            String?
  identifier         String?
  assignedToAgent    Boolean              @default(false)
  agentNotes         String?
  agentStatus        String?
  agentTriggeredAt   DateTime?
  commitHash         String?
  prUrl              String?
  branchName         String?
  previewPort        Int?
  previewPid         Int?
  aiReviewScore      Int?
  aiReviewResult     String?
  aiReviewedAt       DateTime?
  reviewedAt         DateTime?
  reviewedBy         String?
  deployStatus       String?
  deployUrl          String?
  deployedAt         DateTime?
  routineId          String?
  goalId             String?
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  routine            Routine?             @relation(fields: [routineId], references: [id], onDelete: SetNull)
  goal               Goal?                @relation(fields: [goalId], references: [id], onDelete: SetNull)
  sprint             Sprint?              @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee           User?                @relation("AssignedStories", fields: [assigneeId], references: [id], onDelete: SetNull)
  agent              Agent?               @relation("AgentStories", fields: [agentId], references: [id], onDelete: SetNull)
  parent             Story?               @relation("StoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children           Story[]              @relation("StoryParent")
  blockedByDeps      StoryDependency[]    @relation("BlockedStory")
  blockingDeps       StoryDependency[]    @relation("BlockerStory")
  labels             StoryLabel[]
  acceptanceCriteria AcceptanceCriterion[]
  attachments        Attachment[]
  comments           Comment[]
  activities         Activity[]
  costEvents         CostEvent[]          @relation("StoryCosts")
  heartbeatRuns      HeartbeatRun[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([projectId, status])
  @@index([projectId, status, agentStatus])
  @@index([sprintId])
  @@index([parentId])
  @@index([assigneeId])
  @@index([assigneeId, status])
  @@index([agentId])
  @@index([routineId])
  @@index([goalId])
}

model AcceptanceCriterion {
  id        String  @id @default(cuid())
  given     String
  when      String
  then      String
  completed Boolean @default(false)
  position  Int     @default(0)
  storyId   String
  story     Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

model Sprint {
  id        String   @id @default(cuid())
  name      String
  goal      String?
  status    String   @default("PLANNING")
  startDate DateTime?
  endDate   DateTime?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories   Story[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Label {
  id        String       @id @default(cuid())
  name      String
  color     String       @default("#6366f1")
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories   StoryLabel[]

  @@unique([name, projectId])
}

model StoryLabel {
  id      String @id @default(cuid())
  storyId String
  labelId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([storyId, labelId])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  String?
  userId    String?
  projectId String
  storyId   String?
  orgId     String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([storyId])
  @@index([orgId, createdAt])
  @@index([userId])
}

// ─── Comment Model ─────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  storyId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storyId, createdAt])
  @@index([userId])
}

// ─── Notification Model ────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  href      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Org Invite Model ──────────────────────────────────

model OrgInvite {
  id        String       @id @default(cuid())
  email     String
  orgId     String
  role      String       @default("MEMBER")
  token     String       @unique
  expiresAt DateTime
  invitedBy String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([email, orgId])
  @@index([token])
  @@index([orgId])
}

// ─── Audit Log Model ──────────────────────────────────

model AuditLog {
  id        String       @id @default(cuid())
  action    String
  details   String?
  userId    String
  orgId     String
  user      User         @relation("AuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ipAddress String?
  createdAt DateTime     @default(now())

  @@index([orgId, createdAt])
  @@index([userId])
}

// ─── Webhook Model ──────────────────────────────────

model Webhook {
  id         String            @id @default(cuid())
  url        String
  events     String            // JSON array of event names
  secret     String
  active     Boolean           @default(true)
  projectId  String
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([projectId])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  webhookId     String
  event         String
  payload       String    // JSON body
  status        String    @default("PENDING") // PENDING | SUCCESS | FAILED
  httpStatus    Int?
  responseBody  String?   // truncated 1KB
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  nextRetryAt   DateTime?
  lastAttemptAt DateTime?
  errorMessage  String?
  webhook       Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

// ─── Story Dependency Model ──────────────────────────────

model StoryDependency {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   Story    @relation("BlockerStory", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Story    @relation("BlockedStory", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@index([blockerId])
}

// ─── Attachment Model ──────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([storyId])
}

// ─── Recurring Story Model ──────────────────────────────

model RecurringStory {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String    @default("chore")
  priority      String    @default("MEDIUM")
  storyPoints   Int?
  frequency     String    // daily | weekly | monthly
  dayOfWeek     Int?      // 0-6 for weekly
  dayOfMonth    Int?      // 1-31 for monthly
  lastCreatedAt DateTime?
  active        Boolean   @default(true)
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
}

// ─── Saved Filter Model ──────────────────────────────

model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  filters   Json     // { search, priorities, types, labelIds, assigneeIds }
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, userId])
}

// ─── Agent Model ──────────────────────────────────────

model Agent {
  id               String       @id @default(cuid())
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name             String
  role             String       @default("coder")
  title            String?
  icon             String?
  status           String       @default("idle") // idle, running, paused, terminated
  description      String?      // What this agent does — included in prompt context
  capabilities     String?
  adapterType      String       @default("claude") // claude, openai, ollama, http
  adapterConfig    Json?
  reportsTo        String?
  reportingAgent   Agent?       @relation("AgentHierarchy", fields: [reportsTo], references: [id])
  subordinates     Agent[]      @relation("AgentHierarchy")
  pauseReason      String?
  lastHeartbeatAt  DateTime?
  storiesCompleted Int          @default(0)
  totalCostCents   Int          @default(0)
  heartbeatEnabled Boolean      @default(false)
  heartbeatCron    String?
  nextHeartbeatAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assignedStories  Story[]      @relation("AgentStories")
  costEvents       CostEvent[]
  heartbeatRuns    HeartbeatRun[]
  workspaces       ExecutionWorkspace[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([orgId, status])
  @@index([nextHeartbeatAt])
}

// ─── Cost Event Model ─────────────────────────────────

model CostEvent {
  id           String   @id @default(cuid())
  agentId      String?
  agent        Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  storyId      String?
  story        Story?   @relation("StoryCosts", fields: [storyId], references: [id], onDelete: SetNull)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orgId        String
  provider     String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costCents    Int      @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([agentId, createdAt])
  @@index([storyId])
}

// ─── Budget Policy Model ─────────────────────────────

model BudgetPolicy {
  id              String           @id @default(cuid())
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scope           String           // "org", "agent", "project"
  scopeId         String?          // agentId or projectId (null for org scope)
  metric          String           @default("cost_cents")
  window          String           @default("calendar_month") // "calendar_month", "lifetime"
  amountCents     Int              // budget limit in cents
  warnPercent     Int              @default(80)
  hardStopEnabled Boolean          @default(true)
  notifyEnabled   Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  incidents       BudgetIncident[]

  @@index([orgId])
  @@index([orgId, scope, scopeId])
}

// ─── Budget Incident Model ───────────────────────────

model BudgetIncident {
  id            String       @id @default(cuid())
  policyId      String
  policy        BudgetPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  type          String       // "soft_warning", "hard_stop"
  currentCents  Int
  limitCents    Int
  resolvedAt    DateTime?
  approvalId    String?      // links to Approval for budget override
  createdAt     DateTime     @default(now())

  @@index([policyId])
  @@index([policyId, type])
}

// ─── Approval Model ──────────────────────────────────

model Approval {
  id            String            @id @default(cuid())
  orgId         String
  org           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type          String            // "hire_agent", "budget_override"
  status        String            @default("pending") // "pending", "approved", "rejected", "revision_requested"
  payload       Json              // context-specific data
  requestedById String
  requestedBy   User              @relation("ApprovalRequester", fields: [requestedById], references: [id])
  decidedById   String?
  decidedBy     User?             @relation("ApprovalDecider", fields: [decidedById], references: [id])
  decidedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  comments      ApprovalComment[]

  @@index([orgId, status])
  @@index([orgId, type])
  @@index([requestedById])
}

// ─── Approval Comment Model ──────────────────────────

model ApprovalComment {
  id         String   @id @default(cuid())
  approvalId String
  approval   Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  content    String
  createdAt  DateTime @default(now())

  @@index([approvalId, createdAt])
}

// ─── HeartbeatRun Model ──────────────────────────────

model HeartbeatRun {
  id              String    @id @default(cuid())
  agentId         String
  agent           Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  storyId         String?
  story           Story?    @relation(fields: [storyId], references: [id], onDelete: SetNull)
  source          String    // "on_demand", "scheduled", "issue_assignment"
  status          String    @default("queued") // queued, running, succeeded, failed, timed_out
  startedAt       DateTime?
  finishedAt      DateTime?
  exitCode        Int?
  inputTokens     Int?
  outputTokens    Int?
  costCents       Int?
  storiesProcessed Int      @default(0)
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([agentId, createdAt])
  @@index([agentId, status])
  @@index([storyId])
}

// ─── Routine Model ──────────────────────────────────────

model Routine {
  id                String       @id @default(cuid())
  projectId         String
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  storyTemplate     Json         // { title, description, type, priority, storyPoints, labels }
  cronExpression    String
  timezone          String       @default("UTC")
  concurrencyPolicy String       @default("skip_if_active") // always_enqueue, skip_if_active, coalesce_if_active
  webhookEnabled    Boolean      @default(false)
  webhookSecret     String?
  webhookAuthType   String       @default("none") // hmac, bearer, none
  active            Boolean      @default(true)
  lastTriggeredAt   DateTime?
  nextTriggerAt     DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  runs              RoutineRun[]
  stories           Story[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([active, nextTriggerAt])
}

// ─── Routine Run Model ──────────────────────────────────

model RoutineRun {
  id              String    @id @default(cuid())
  routineId       String
  routine         Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
  source          String    // "scheduled", "on_demand", "webhook"
  status          String    @default("pending") // pending, running, completed, failed, skipped
  storyId         String?
  skipReason      String?
  webhookPayload  Json?
  createdAt       DateTime  @default(now())

  @@index([routineId, status])
  @@index([routineId, createdAt])
}

// ─── Execution Workspace Model ──────────────────────────

model ExecutionWorkspace {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentId     String?
  agent       Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workingDir  String
  branchName  String?
  cloneUrl    String?
  status      String       @default("active") // active, closed
  closedAt    DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([agentId])
  @@index([projectId])
  @@index([orgId, status])
}

// ─── Read State Model ───────────────────────────────────

model ReadState {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType String   // story, comment, approval
  entityId   String
  readAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId, entityType])
  @@index([entityId])
}

model Goal {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  level        String   @default("project") // company, team, project
  status       String   @default("planned") // planned, active, completed
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentId     String?
  parent       Goal?    @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Goal[]   @relation("GoalHierarchy")
  ownerAgentId String?
  stories      Story[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
  @@index([parentId])
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ─────────────────────────────────────

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String?       @unique
  emailVerified    DateTime?
  image            String?
  plan             String        @default("FREE")
  lemonSqueezyCustomerId String?  @unique
  currentOrgId     String?
  deletedAt        DateTime?
  onboardingCompleted Boolean       @default(false)
  notificationPrefs    String?       // JSON: { email: boolean, inApp: boolean, digest: "instant"|"daily"|"off" }
  emailUnsubscribeToken String?     @unique
  accounts         Account[]
  sessions         Session[]
  projects         ProjectMember[]
  orgMemberships   OrgMember[]
  activities       Activity[]
  assignedStories  Story[]        @relation("AssignedStories")
  comments         Comment[]
  notifications    Notification[]
  passwordHash        String?
  passwordResetToken  String?       @unique
  passwordResetExpiry DateTime?
  isAdmin             Boolean       @default(false)
  totpSecret          String?
  totpEnabled         Boolean       @default(false)
  totpBackupCodes     String?
  auditLogs        AuditLog[]     @relation("AuditLogs")
  subscription     Subscription?
  currentOrg       Organization? @relation("UserCurrentOrg", fields: [currentOrgId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([currentOrgId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                     String        @id @default(cuid())
  userId                 String?       @unique
  orgId                  String?       @unique
  externalSubscriptionId String        @unique
  productId              String
  currentPeriodEnd       DateTime
  status                 String
  user                   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization           Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

// ─── Organization Models ────────────────────────────────

model Organization {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  plan             String        @default("FREE")
  lemonSqueezyCustomerId String?  @unique
  isPersonal       Boolean       @default(false)
  members          OrgMember[]
  projects         Project[]
  invites          OrgInvite[]
  auditLogs        AuditLog[]
  subscription     Subscription?
  usersWithCurrent User[]        @relation("UserCurrentOrg")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model OrgMember {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      String       @default("MEMBER")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
}

// ─── Application Models ──────────────────────────────────

model Project {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  techStack     String?
  githubRepo    String?
  orgId            String?
  webhookSecret    String?
  apiKey           String?         @unique
  apiKeyHash       String?
  apiKeyPrefix     String?
  apiKeyLastRotated DateTime?
  isPublic         Boolean         @default(false)
  agentAutoAssign  Boolean         @default(false)
  agentMinPriority String          @default("HIGH")
  agentWorkingDir  String?
  aiProvider       String          @default("ollama")
  aiApiKey         String?
  maxConcurrentAgents Int          @default(1)
  deployProvider   String?
  deployToken      String?
  deployProjectId  String?
  org              Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members          ProjectMember[]
  stories       Story[]
  sprints       Sprint[]
  labels        Label[]
  activities    Activity[]
  webhooks      Webhook[]
  recurringStories RecurringStory[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orgId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      String      @default("OWNER")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model Story {
  id                 String               @id @default(cuid())
  shortId            String               @unique
  title              String
  description        String?
  rawInput           String?
  userStory          String?
  status             String               @default("BACKLOG")
  priority           String               @default("MEDIUM")
  type               String               @default("feature")
  storyPoints        Int?
  position           Int                  @default(0)
  projectId          String
  sprintId           String?
  assigneeId         String?
  parentId           String?
  assignedToAgent    Boolean              @default(false)
  agentNotes         String?
  agentStatus        String?
  agentTriggeredAt   DateTime?
  commitHash         String?
  prUrl              String?
  branchName         String?
  previewPort        Int?
  previewPid         Int?
  aiReviewScore      Int?
  aiReviewResult     String?
  aiReviewedAt       DateTime?
  deployStatus       String?
  deployUrl          String?
  deployedAt         DateTime?
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint             Sprint?              @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee           User?                @relation("AssignedStories", fields: [assigneeId], references: [id], onDelete: SetNull)
  parent             Story?               @relation("StoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children           Story[]              @relation("StoryParent")
  blockedByDeps      StoryDependency[]    @relation("BlockedStory")
  blockingDeps       StoryDependency[]    @relation("BlockerStory")
  labels             StoryLabel[]
  acceptanceCriteria AcceptanceCriterion[]
  attachments        Attachment[]
  comments           Comment[]
  activities         Activity[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([projectId, status])
  @@index([sprintId])
  @@index([parentId])
  @@index([assigneeId])
}

model AcceptanceCriterion {
  id        String  @id @default(cuid())
  given     String
  when      String
  then      String
  completed Boolean @default(false)
  position  Int     @default(0)
  storyId   String
  story     Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

model Sprint {
  id        String   @id @default(cuid())
  name      String
  goal      String?
  status    String   @default("PLANNING")
  startDate DateTime?
  endDate   DateTime?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories   Story[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Label {
  id        String       @id @default(cuid())
  name      String
  color     String       @default("#6366f1")
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stories   StoryLabel[]

  @@unique([name, projectId])
}

model StoryLabel {
  id      String @id @default(cuid())
  storyId String
  labelId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([storyId, labelId])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  String?
  userId    String?
  projectId String
  storyId   String?
  orgId     String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([storyId])
  @@index([orgId, createdAt])
  @@index([userId])
}

// ─── Comment Model ─────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  storyId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storyId, createdAt])
  @@index([userId])
}

// ─── Notification Model ────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  href      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Org Invite Model ──────────────────────────────────

model OrgInvite {
  id        String       @id @default(cuid())
  email     String
  orgId     String
  role      String       @default("MEMBER")
  token     String       @unique
  expiresAt DateTime
  invitedBy String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([email, orgId])
  @@index([token])
  @@index([orgId])
}

// ─── Audit Log Model ──────────────────────────────────

model AuditLog {
  id        String       @id @default(cuid())
  action    String
  details   String?
  userId    String
  orgId     String
  user      User         @relation("AuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ipAddress String?
  createdAt DateTime     @default(now())

  @@index([orgId, createdAt])
  @@index([userId])
}

// ─── Webhook Model ──────────────────────────────────

model Webhook {
  id         String            @id @default(cuid())
  url        String
  events     String            // JSON array of event names
  secret     String
  active     Boolean           @default(true)
  projectId  String
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([projectId])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  webhookId     String
  event         String
  payload       String    // JSON body
  status        String    @default("PENDING") // PENDING | SUCCESS | FAILED
  httpStatus    Int?
  responseBody  String?   // truncated 1KB
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  nextRetryAt   DateTime?
  lastAttemptAt DateTime?
  errorMessage  String?
  webhook       Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

// ─── Story Dependency Model ──────────────────────────────

model StoryDependency {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   Story    @relation("BlockerStory", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Story    @relation("BlockedStory", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@index([blockerId])
}

// ─── Attachment Model ──────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([storyId])
}

// ─── Recurring Story Model ──────────────────────────────

model RecurringStory {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String    @default("chore")
  priority      String    @default("MEDIUM")
  storyPoints   Int?
  frequency     String    // daily | weekly | monthly
  dayOfWeek     Int?      // 0-6 for weekly
  dayOfMonth    Int?      // 1-31 for monthly
  lastCreatedAt DateTime?
  active        Boolean   @default(true)
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
}

# Database (PostgreSQL)
DATABASE_URL="postgresql://codepylot:codepylot@localhost:5432/codepylot"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXT_PUBLIC_GOOGLE_ENABLED=""              # Set to "true" to show Google sign-in button
AUTH_TRUST_HOST=true

# Anthropic
ANTHROPIC_API_KEY=""

# Ollama (default: http://localhost:11434/v1, use http://ollama:11434/v1 inside Docker)
OLLAMA_URL="http://localhost:11434/v1"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Paddle (billing)
PADDLE_API_KEY=""                          # Server-side API key (pdl_xxx)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""         # Client-side token (ptk_xxx)
PADDLE_WEBHOOK_SECRET=""                   # Webhook signing secret
PADDLE_PRO_PRICE_ID=""                     # Price ID for Pro ($19/mo)
PADDLE_PRO_MAX_PRICE_ID=""                 # Price ID for Pro Max ($39/mo)
PADDLE_ENVIRONMENT="sandbox"               # "sandbox" or "production"
NEXT_PUBLIC_PADDLE_ENVIRONMENT="sandbox"   # Client-side environment
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=""         # Client-side Pro price ID
NEXT_PUBLIC_PADDLE_PRO_MAX_PRICE_ID=""     # Client-side Pro Max price ID

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Codepylot <notifications@codepylot.dev>"

# Upstash Redis (optional — falls back to in-memory rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Encryption (required — encrypts API keys at rest)
ENCRYPTION_KEY="generate-with: openssl rand -base64 32"

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""                # PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=""               # PostHog host (default: https://us.i.posthog.com)

# Cron (required — protects /api/cron/* endpoints)
CRON_SECRET="generate-with: openssl rand -base64 32"

# Database (PostgreSQL)
DATABASE_URL="postgresql://shipflow:shipflow@localhost:5432/shipflow"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXT_PUBLIC_GOOGLE_ENABLED=""              # Set to "true" to show Google sign-in button
AUTH_TRUST_HOST=true

# Anthropic
ANTHROPIC_API_KEY=""

# Ollama (default: http://localhost:11434/v1, use http://ollama:11434/v1 inside Docker)
OLLAMA_URL="http://localhost:11434/v1"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_PRO_VARIANT_ID=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="ShipFlow <notifications@shipflow.dev>"

# Upstash Redis (optional — falls back to in-memory rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cron (required — protects /api/cron/* endpoints)
CRON_SECRET="generate-with: openssl rand -base64 32"

# Database (PostgreSQL)
DATABASE_URL="postgresql://shipflow:shipflow@localhost:5432/shipflow"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_TRUST_HOST=true

# Anthropic
ANTHROPIC_API_KEY=""

# Ollama (default: http://localhost:11434/v1, use http://ollama:11434/v1 inside Docker)
OLLAMA_URL="http://localhost:11434/v1"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
